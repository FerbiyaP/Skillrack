import java.util.*;

public class Hello {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.nextLine();

        HashSet<Character> set = new HashSet<>();
        char repeat = '\0';

        for (char c : s.toCharArray()) {
            if (set.contains(c)) {
                repeat = c;
                break;          
            }
            set.add(c);         
        }

        System.out.println(repeat);
    }
}
